PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/ecommerce
JWT_SECRET=replace-with-a-long-random-string-at-least-16-chars

# Optional: comma-separated browser origins allowed by CORS (your deployed app URLs).
# Leave unset in dev to allow all origins. Set in production.
# CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# Optional: max JSON body size (default 1mb)
# JSON_BODY_LIMIT=1mb

# Admin seeder: npm run seed:admin
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASS=your-secure-password

# Inventory alerts (admin dashboard "low stock" uses countInStock <= this)
# LOW_STOCK_THRESHOLD=5

# Stripe — Dashboard → Developers → API keys. Paste your **secret** key (test or live) here locally only; never commit real keys.
STRIPE_SECRET_KEY=

# Stripe webhook signing secret (Dashboard → Developers → Webhooks). Required for POST /api/payment/webhook
# STRIPE_WEBHOOK_SECRET=whsec_...

# Cloudinary (admin product image upload). Optional: leave unset and use image URLs only.
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# Public storefront URL (password reset links). No trailing slash. Required for reset emails in production.
# FRONTEND_URL=https://yourdomain.com

# Email (order confirmation). Leave unset to log to console only.
# Gmail/app passwords or any SMTP provider works.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-smtp-password
# EMAIL_FROM=orders@yourdomain.com
# STORE_NAME=SHOP.CO
# Used in transactional emails (order, shipping, password reset) and the From: display name.
# TEST_EMAIL_TO=you@example.com   # optional; default is SMTP_USER (send test to yourself)
