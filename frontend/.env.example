# Backend API origin, no trailing slash, no /api suffix (required unless the app is served behind the same host as /api).
# Production example: VITE_API_URL=https://api.yourdomain.com
# Leave empty only if the browser loads the API at the same origin under /api.
VITE_API_URL=

# Optional (development only): backend origin to proxy /api to when using an empty VITE_API_URL.
# Set this in .env.local; do not commit real URLs if you prefer.
# VITE_DEV_API_TARGET=

# Password reset emails use FRONTEND_URL on the server (see backend/.env.example).

# Stripe publishable key — same Dashboard → API keys. Paste locally; never commit real keys.
# Must match the Stripe account used by STRIPE_SECRET_KEY on the server.
VITE_STRIPE_PUBLISHABLE_KEY=
